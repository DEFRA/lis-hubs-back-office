{
  "name": "@livestock/hub-back-office",
  "private": true,
  "version": "0.1.0",
  "description": "Back-office hub application for the livestock platform.",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "build:frontend": "vite build",
    "predev": "npm run build:frontend",
