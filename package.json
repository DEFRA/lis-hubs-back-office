    "@livestock/hub-core": "file:../infra-core",
    "@livestock/hub-registry": "file:../infra-registry",
    "@livestock/ui-services": "file:../../infra/ui-services",
    "blankie": "5.0.0",
    "convict": "6.2.5",
    "convict-format-with-validator": "6.2.0",
    "govuk-frontend": "6.1.0"
