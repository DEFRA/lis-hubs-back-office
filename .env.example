PORT=3102
BASE_PATH=
NODE_ENV=development
LOG_FORMAT=pino-pretty
SESSION_COOKIE_SECURE=false
SESSION_CACHE_ENGINE=memory
SESSION_CACHE_NAME=back-office-session
SESSION_CACHE_TTL=14400000
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_TLS=false
USE_SINGLE_INSTANCE_CACHE=true
HUB_ORIGIN=http://localhost:3000
HUB_JWT_ISSUER=http://localhost:3000
HUB_JWT_AUDIENCE=livestock-spokes
HUB_JWT_COOKIE_NAME=livestock_hub_jwt
HUB_JWT_SECRET=local-dev-hub-jwt-signing-secret-please-change-1234567890
HUB_JWT_TTL_SECONDS=14400
AUTH_PRIMARY_PROVIDER=entra
OIDC_DISCOVERY_URL=https://replace-with-real-entra-id/.well-known/openid-configuration
OIDC_CLIENT_ID=back-office-entra-client
OIDC_CLIENT_SECRET=back-office-entra-client-secret
OIDC_SERVICE_ID=
OIDC_REDIRECT_PATH=/sso
